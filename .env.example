# ================================
# AI 动漫视频生成平台 - 环境变量配置
# ================================

# Supabase 数据库
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI 服务 (中转站 API，通用)
AI_API_BASE_URL=https://api.vectorengine.ai/v1
AI_API_KEY=your-api-key

# Claude API (剧本解析)
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Gemini 图片生成 (优先级高于 AI_API_KEY / AI_API_BASE_URL)
GEMINI_API_BASE_URL=https://api.vectorengine.ai
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-pro-image-preview

# Flux Pro (图像生成)
FLUX_MODEL=flux-pro

# Veo 视频生成
VEO_API_BASE_URL=https://api.vectorengine.ai
VEO_API_KEY=your-veo-api-key
VEO_MODEL=veo3-fast

# MiniMax 官方 API (海螺视频生成)
# 获取地址: https://platform.minimaxi.com/
MINIMAX_API_KEY=your-minimax-api-key

# ToApis (Sora2 视频生成)
# 获取地址: https://toapis.com
TOAPIS_API_KEY=your-toapis-api-key
TOAPIS_API_BASE_URL=https://toapis.com/v1

# SillyDream (Sora2 视频生成 + Gemini 图片生成)
# 获取地址: https://docs.newapi.pro
SILLYDREAM_API_KEY=your-sillydream-api-key
SILLYDREAM_API_BASE_URL=https://api.sillydream.com/v1
SILLYDREAM_GEMINI_MODEL=gemini-2.0-flash-exp-image-generation

# Suno (BGM 生成)
SUNO_API_KEY=your-suno-key

# ElevenLabs (音效和配音)
ELEVENLABS_API_KEY=your-elevenlabs-key

# Inngest (任务编排)
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# 阿里云 OSS (文件存储，用于 ToApis 等不支持 base64 的 API)
# 获取地址: https://oss.console.aliyun.com
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OSS_BUCKET=your-bucket-name
# 可选：自定义域名（如果有 CDN 加速）
# ALIYUN_OSS_CUSTOM_DOMAIN=cdn.example.com

# Cloudflare R2 (备用文件存储)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com

# 应用配置
NEXT_PUBLIC_APP_URL=http://localhost:3000
